# =============================================================================
# DeerFlow Hello World Demo - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# cp .env.example .env

# =============================================================================
# SEARCH ENGINE API KEYS
# =============================================================================

# Tavily API Key (Required for web search)
# Get your free API key at: https://app.tavily.com
TAVILY_API_KEY=your-tavily-api-key-here

# Alternative: Brave Search (Optional, uncomment if using)
# BRAVE_SEARCH_API_KEY=your-brave-search-key-here

# =============================================================================
# OLLAMA CONFIGURATION
# =============================================================================

# Ollama Base URL (default)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama Model (should match config.yaml)
OLLAMA_MODEL=glm-4.7-flash:latest

# =============================================================================
# OPTIONAL: OTHER API KEYS (Not needed for this demo)
# =============================================================================

# OpenAI API Key (if you want to try cloud models later)
# OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API Key (for Claude models)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google Gemini API Key
# GOOGLE_API_KEY=your-google-api-key-here

# DashScope API Key (for Qwen models via cloud)
# DASHSCOPE_API_KEY=your-dashscope-key-here

# MiniMax API Key
# MINIMAX_API_KEY=your-minimax-key-here

# =============================================================================
# VOLCENGINE TTS (Optional, for text-to-speech)
# =============================================================================
# VOLCENGINE_TTS_ACCESS_KEY=your-volcengine-access-key
# VOLCENGINE_TTS_SECRET_KEY=your-volcengine-secret-key

# =============================================================================
# LANGSMITH TRACING (Optional, for debugging)
# =============================================================================
# LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=your-langsmith-key-here
# LANGSMITH_PROJECT=deer-flow-demo

# =============================================================================
# ADVANCED SETTINGS
# =============================================================================

# Configuration file path (optional, defaults to ./config.yaml)
# DEER_FLOW_CONFIG_PATH=./config.yaml

# Log level override (optional)
# DEER_FLOW_LOG_LEVEL=INFO

# Enable debug mode
# DEER_FLOW_DEBUG=false
